{
  "description": "Keep the Tutti Codex plugin marketplace fresh between sessions.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/scripts/auto-update-codex-plugin.sh",
            "timeout": 30,
            "statusMessage": "Checking Tutti plugin updates"
          }
        ]
      }
    ]
  }
}
